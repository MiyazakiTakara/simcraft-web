# Blizzard OAuth (https://develop.battle.net/)
BLIZZARD_CLIENT_ID=twoj_client_id
BLIZZARD_CLIENT_SECRET=twoj_client_secret

# Produkcja: pelny URL callbacku zarejestrowany w Blizzard Dev Portal
# Development: http://localhost:8000/auth/callback
REDIRECT_URI=https://twoja-domena.com/auth/callback

# CORS - dozwolone originy (przecinek jako separator)
# Development: *
# Produkcja: https://twoja-domena.com
ALLOWED_ORIGINS=https://twoja-domena.com

# Maks rownoczesnych symulacji (zalezy od CPU serwera)
MAX_CONCURRENT_SIMS=3

# Katalog wynikow
RESULTS_DIR=/app/results

# Klucz sesji (wygeneruj: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=zmien_mnie_na_losowy_string
